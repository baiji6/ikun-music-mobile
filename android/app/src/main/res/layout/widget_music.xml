<?xml version="1.0" encoding="utf-8"?>
<!-- 音乐桌面小组件布局 -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="8dp"
    android:background="@drawable/widget_background">

    <!-- 专辑封面区域 -->
    <ImageView
        android:id="@+id/widget_album_art"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_widget_default_album"
        android:contentDescription="专辑封面" />

    <!-- 歌曲信息区域 -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="8dp">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:singleLine="true"
            android:ellipsize="end"
            android:text="未知歌曲" />

        <TextView
            android:id="@+id/widget_artist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#B3FFFFFF"
            android:singleLine="true"
            android:ellipsize="end"
            android:text="未知艺术家"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <!-- 播放/暂停按钮 -->
    <ImageView
        android:id="@+id/widget_btn_play_pause"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:padding="6dp"
        android:src="@drawable/ic_widget_play"
        android:contentDescription="播放/暂停"
        android:background="?attr/selectableItemBackgroundBorderless" />

    <!-- 下一曲按钮 -->
    <ImageView
        android:id="@+id/widget_btn_next"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:padding="6dp"
        android:src="@drawable/ic_widget_next"
        android:contentDescription="下一曲"
        android:background="?attr/selectableItemBackgroundBorderless" />

</LinearLayout>